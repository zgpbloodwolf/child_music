# 后端服务配置模板:复制为 .env 后按实际修改
# 监听地址与端口(由 Nginx Proxy Manager 转发到公网)
HOST=0.0.0.0
PORT=8823

# 反向代理的子路径前缀(公网入口为 .../childmusic)
ROOT_PATH=/childmusic

# 公网访问基础 URL:用于把相对音频/封面路径拼成完整 URL 返回给前端
# 替换为你的真实公网入口(经 Nginx Proxy Manager 暴露),生产务必用 HTTPS
PUBLIC_BASE_URL=https://your-domain.example.com/childmusic

# 音频/封面文件存储根目录(相对 server/ 目录;镜像 src/static/library 结构)
STORAGE_ROOT=storage

# SQLite 数据库路径(相对 server/ 目录)
DB_PATH=data/music.db

# 管理接口鉴权 token:上线前请改为强随机串
ADMIN_TOKEN=change-me-to-a-strong-random-string

# CORS 白名单(逗号分隔;开发期可用 *;生产建议填具体 H5 域名)
CORS_ORIGINS=*

# App 整包更新配置(每次发版同步更新;详见仓库 docs 或 src/utils/appUpdate.ts)
# 最新版本号(versionName,如 1.0.1);versionCode 由其派生,须与 manifest.json 的 versionName 一致
APP_VERSION=1.0.0
# APK 下载完整 URL:后端分发可填 https://your-domain.example.com/childmusic/library/apk/app-release.apk
# 也可填外链(如 GitHub Release 资产直链);留空时客户端仅提示不下载
APP_DOWNLOAD_URL=
# 更新说明(展示在更新弹窗内容区,\n 换行)
APP_RELEASE_NOTES=
# 是否强制更新(true 时用户不可跳过该版本)
APP_FORCE_UPDATE=false
