# 后端服务配置模板:复制为 .env 后按实际修改
# 监听地址与端口(由 Nginx Proxy Manager 转发到公网)
HOST=0.0.0.0
PORT=8823

# 反向代理的子路径前缀(公网入口为 .../childmusic)
ROOT_PATH=/childmusic

# 公网访问基础 URL:用于把相对音频/封面路径拼成完整 URL 返回给前端
PUBLIC_BASE_URL=http://zgp.vip.cpolar.cn/childmusic

# 音频/封面文件存储根目录(相对 server/ 目录;镜像 src/static/library 结构)
STORAGE_ROOT=storage

# SQLite 数据库路径(相对 server/ 目录)
DB_PATH=data/music.db

# 管理接口鉴权 token:上线前请改为强随机串
ADMIN_TOKEN=change-me-to-a-strong-random-string

# CORS 白名单(逗号分隔;开发期可用 *;生产建议填具体 H5 域名)
CORS_ORIGINS=*
