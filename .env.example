# 环境变量模板。使用前复制本文件为 .env 并填入实际值(.env 不入库,见 .gitignore)。
# 这些变量在代码里通过 import.meta.env.VITE_xxx 读取(VITE_ 前缀由 Vite 在编译期注入)。

# 运行环境:local=本机联调 / online=线上公网
VITE_APP_ENV=local

# 各环境后端基础地址(含反向代理子路径前缀 /childmusic)。
# 注意:App(真机/模拟器)中 127.0.0.1 指向手机自身,联调时务必填开发机局域网 IP,
# 且保证手机与电脑同一 WiFi、电脑防火墙放行 8823。IP 由 DHCP 分配,变化时同步更新。
VITE_API_BASE_URL_LOCAL=http://<开发机局域网IP>:8823/childmusic

# 上线前替换为真实公网地址(经 Nginx Proxy Manager 暴露的 HTTPS 入口)
VITE_API_BASE_URL_ONLINE=https://your-domain.example.com/childmusic
